---
import MobileCommandList from '../command/MobileCommandList.astro';

interface Props {
  commands: any[];
}

const { commands: commandList } = Astro.props;
---

<div class="min-h-screen px-3 pb-8">
  <!-- Vista de lista de comandos -->
  <div id="mobile-list-view" class="w-full surface-elevated overflow-hidden soft-reveal">
    <!-- Header -->
    <div class="p-4 border-b border-slate-200/80 dark:border-slate-700/80 bg-white/70 dark:bg-slate-800/75">
      <h1 class="text-xl font-extrabold text-slate-800 dark:text-slate-100 mb-1">TechSec CheatSheet</h1>
      <div class="text-sm text-slate-600 dark:text-slate-400">
        <span id="mobile-command-count">{commandList.length}</span> comandos disponibles
      </div>
    </div>

    <!-- Lista de comandos -->
    <div class="p-4 bg-transparent">
      <MobileCommandList commands={commandList} />
    </div>
  </div>

  <!-- Vista de detalle del comando -->
  <div id="mobile-detail-view" class="hidden w-full surface-elevated min-h-screen overflow-hidden" aria-hidden="true">
    <!-- Header del detalle -->
    <div class="p-4 border-b border-slate-200/80 dark:border-slate-700/80 flex items-center justify-between bg-white/80 dark:bg-slate-800/80 sticky top-0 z-10 backdrop-blur">
      <div class="flex items-center">
        <button
          onclick="showMobileList()"
          aria-label="Volver a la lista de comandos"
          class="mr-3 p-2 text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-500"
        >
          <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <h2 id="detail-title" class="text-lg font-bold text-gray-800 dark:text-gray-100">Detalle del comando</h2>
      </div>
    </div>

    <!-- Contenido del detalle -->
    <div class="flex-1 overflow-y-auto bg-transparent">
      <div id="mobile-detail-content" class="p-4 min-h-full">
        <!-- Placeholder inicial -->
        <div class="text-center py-12">
          <div class="text-gray-400 dark:text-gray-500 mb-4" aria-hidden="true">
            <svg class="h-16 w-16 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-200 mb-2">Selecciona un comando</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm">Elige un comando de la lista para ver su documentación completa</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function showMobileList() {
  const listView = document.getElementById('mobile-list-view');
  const detailView = document.getElementById('mobile-detail-view');

  if (listView && detailView) {
    listView.classList.remove('hidden');
    listView.removeAttribute('aria-hidden');
    detailView.classList.add('hidden');
    detailView.setAttribute('aria-hidden', 'true');
  }
}

function showMobileDetail(commandTitle: string) {
  const listView = document.getElementById('mobile-list-view');
  const detailView = document.getElementById('mobile-detail-view');
  const detailTitle = document.getElementById('detail-title');
  const detailContent = document.getElementById('mobile-detail-content');

  if (!listView || !detailView || !detailTitle || !detailContent) {
    console.error('Elementos del DOM no encontrados');
    return;
  }

  detailTitle.textContent = commandTitle;

  detailContent.innerHTML = `
    <div class="flex items-center justify-center py-12">
      <div class="animate-spin rounded-full h-10 w-10 border-4 border-blue-200 border-t-blue-600" aria-hidden="true"></div>
      <span class="ml-4 text-gray-600 dark:text-gray-400 font-medium">Cargando contenido...</span>
    </div>
  `;

  listView.classList.add('hidden');
  listView.setAttribute('aria-hidden', 'true');
  detailView.classList.remove('hidden');
  detailView.removeAttribute('aria-hidden');

  if ((window as any).loadCommandDetail) {
    (window as any).loadCommandDetail(commandTitle);
  } else {
    console.error('loadCommandDetail no está disponible');
  }
}

(window as any).showMobileList = showMobileList;
(window as any).showMobileDetail = showMobileDetail;

window.addEventListener('DOMContentLoaded', () => {
  const originalShowPreview = (window as any).showPreview;

  if (originalShowPreview) {
    (window as any).showPreview = function(commandTitle: string) {
      if (window.innerWidth < 1024) {
        showMobileDetail(commandTitle);
      } else {
        originalShowPreview(commandTitle);
      }
    };
  }
});
</script>
