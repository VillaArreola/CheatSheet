---
interface Props {
  commands: Array<{
    id: string;
    title: string;
    description?: string;
    category: string;
    command?: string;
    syntax?: string;
    tags?: string[];
  }>;
}

const { commands } = Astro.props;

function slugify(value: string): string {
  return value.toLowerCase().replace(/\s+/g, '').replace(/[^a-z0-9]/g, '');
}

const commandData = commands.map(cmd => ({
  title: cmd.title,
  description: cmd.description || '',
  category: cmd.category,
  slug: slugify(cmd.title),
  tags: (cmd.tags || []).join(' '),
}));
---

<div class="relative w-full" id="search-wrapper">
  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none" aria-hidden="true">
    <svg class="h-5 w-5 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
  </div>
  <input
    id="search-input"
    type="search"
    placeholder="Buscar comandos..."
    aria-label="Buscar comandos"
    aria-autocomplete="list"
    aria-controls="search-results"
    aria-expanded="false"
    role="combobox"
    class="w-full pl-10 pr-4 py-2.5 sm:py-3 border border-slate-200/90 dark:border-slate-700 rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 text-sm sm:text-base bg-white/85 dark:bg-slate-800/85 focus:bg-white dark:focus:bg-slate-800 text-slate-900 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 transition-all touch-manipulation shadow-sm"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
    spellcheck="false"
  />
  <div
    id="search-results"
    role="listbox"
    aria-label="Resultados de búsqueda"
    class="hidden absolute top-full left-0 right-0 mt-1 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl z-[60] max-h-80 overflow-y-auto"
  ></div>
</div>

<script define:vars={{ commandData }}>
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  if (input && results) {
    let activeIndex = -1;
    let filtered = [];

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function highlight(text, query) {
      const idx = text.toLowerCase().indexOf(query.toLowerCase());
      if (idx === -1) return escapeHtml(text);
      return (
        escapeHtml(text.slice(0, idx)) +
        '<mark class="bg-sky-200 dark:bg-sky-700 rounded px-0.5">' +
        escapeHtml(text.slice(idx, idx + query.length)) +
        '</mark>' +
        escapeHtml(text.slice(idx + query.length))
      );
    }

    function closeResults() {
      results.classList.add('hidden');
      input.setAttribute('aria-expanded', 'false');
      activeIndex = -1;
      filtered = [];
    }

    function setActive(index) {
      const items = results.querySelectorAll('[role="option"]');
      items.forEach((el, i) => {
        const isActive = i === index;
        el.setAttribute('aria-selected', String(isActive));
        el.classList.toggle('bg-slate-100', isActive);
        el.classList.toggle('dark:bg-slate-800', isActive);
      });
      activeIndex = index;
    }

    function renderResults(query) {
      const term = query.trim();
      if (!term) {
        closeResults();
        return;
      }

      const lower = term.toLowerCase();
      filtered = commandData
        .filter(cmd => {
          const haystack = [cmd.title, cmd.description, cmd.category, cmd.tags].join(' ').toLowerCase();
          return haystack.includes(lower);
        })
        .slice(0, 8);

      if (filtered.length === 0) {
        results.innerHTML = `<p class="px-4 py-3 text-sm text-slate-500 dark:text-slate-400">Sin resultados para "<strong>${escapeHtml(term)}</strong>"</p>`;
      } else {
        results.innerHTML = filtered
          .map(
            (cmd, i) => `
            <a
              href="/${cmd.slug}"
              role="option"
              aria-selected="false"
              data-index="${i}"
              class="flex flex-col px-4 py-3 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors border-b border-slate-100 dark:border-slate-700/60 last:border-0 focus:outline-none focus-visible:bg-slate-100 dark:focus-visible:bg-slate-700"
            >
              <span class="font-semibold text-sm text-slate-800 dark:text-slate-100 font-mono">${highlight(cmd.title, term)}</span>
              ${cmd.description ? `<span class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 line-clamp-1">${escapeHtml(cmd.description)}</span>` : ''}
              <span class="text-[10px] uppercase tracking-wider text-sky-600 dark:text-sky-400 mt-0.5">${escapeHtml(cmd.category)}</span>
            </a>
          `
          )
          .join('');
      }

      results.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
      activeIndex = -1;
    }

    input.addEventListener('input', e => {
      renderResults(e.target.value);
    });

    input.addEventListener('keydown', e => {
      if (results.classList.contains('hidden')) return;
      const items = results.querySelectorAll('[role="option"]');

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(Math.min(activeIndex + 1, items.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, -1));
      } else if (e.key === 'Enter' && activeIndex >= 0) {
        e.preventDefault();
        items[activeIndex].click();
      } else if (e.key === 'Escape') {
        closeResults();
        input.blur();
      }
    });

    input.addEventListener('blur', () => {
      setTimeout(() => {
        if (!document.activeElement?.closest('#search-results')) {
          closeResults();
        }
      }, 150);
    });

    document.addEventListener('click', e => {
      if (!e.target.closest('#search-wrapper')) {
        closeResults();
      }
    });
  }
</script>
