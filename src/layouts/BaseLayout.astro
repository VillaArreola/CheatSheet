---
import '../styles/global.css';
import GoogleAnalytics from '../components/analytics/GoogleAnalytics.astro';
import CookieBanner from '../components/ui/CookieBanner.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const { 
  title, 
  description = "Tu guía completa de comandos de seguridad y hacking ético. Documentación actualizada desde Notion con las mejores prácticas para pentesting, CTF y seguridad informática.",
  image = "/og-image.jpg",
  canonical = Astro.url.href
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Villa Arreola" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="TechSec Cheatsheet" />
    <meta property="og:locale" content="es_ES" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
    <meta property="twitter:creator" content="@VillaArreola" />
    
    <!-- Additional Meta Tags -->
    <meta name="keywords" content="hacking ético, pentesting, comandos linux, seguridad informática, CTF, cheatsheet, comandos terminal, cybersecurity" />
    <meta name="theme-color" content="#3B82F6" />
    <meta name="msapplication-TileColor" content="#3B82F6" />
    <ClientRouter />
    
    <GoogleAnalytics />
    <script>
      // Prevenir flash inicial y exponer funciones globales de tema antes del render
      (function() {
        const STORAGE_KEY = 'theme-mode';
        const VALID_MODES = ['black', 'vault'];

        const applyThemeMode = (mode: string) => {
          const normalizedMode = VALID_MODES.includes(mode) ? mode : 'vault';
          const root = document.documentElement;

          root.classList.remove('dark', 'theme-black', 'theme-vault');

          root.classList.add('dark');
          if (normalizedMode === 'black') {
            root.classList.add('theme-black');
          } else {
            root.classList.add('theme-vault');
          }

          localStorage.setItem(STORAGE_KEY, normalizedMode);
          window.dispatchEvent(new CustomEvent('themeModeChanged', { detail: { mode: normalizedMode } }));
        };

        const getCurrentMode = () => {
          const savedThemeMode = localStorage.getItem(STORAGE_KEY);
          if (savedThemeMode && VALID_MODES.includes(savedThemeMode)) return savedThemeMode;
          return 'vault';
        };

        applyThemeMode(getCurrentMode());

        // Propagar clases de tema al documento entrante ANTES del swap de View Transitions
        // Evita el flash blanco cuando ClientRouter navega entre páginas
        document.addEventListener('astro:before-swap', (e: any) => {
          const mode = getCurrentMode();
          const root = e.newDocument.documentElement;
          root.classList.remove('dark', 'theme-black', 'theme-vault');
          root.classList.add('dark');
          root.classList.add(mode === 'black' ? 'theme-black' : 'theme-vault');
        });

        // Exponer helpers globales
        (window as any).__setThemeMode = (mode: string) => applyThemeMode(mode);
        (window as any).__getThemeMode = () => getCurrentMode();
        (window as any).__toggleTheme = () => {
          const current = getCurrentMode();
          const next = current === 'vault' ? 'black' : 'vault';
          applyThemeMode(next);
        };

        // Delegación: toggle ciclico y selector explicito
        window.addEventListener('DOMContentLoaded', () => {
          document.addEventListener('click', (ev) => {
            const target = ev.target as HTMLElement;
            if (!target || typeof target.closest !== 'function') return;

            const toggleButton = target.closest('#dark-mode-toggle');
            if (toggleButton) {
              (window as any).__toggleTheme();
              return;
            }

            const modeButton = target.closest('[data-theme-mode]') as HTMLElement | null;
            if (modeButton?.dataset?.themeMode) {
              (window as any).__setThemeMode(modeButton.dataset.themeMode);
              return;
            }
          });
        });
      })();
    </script>
  </head>
  <body class="site-bg min-h-screen text-slate-900 dark:text-slate-100 transition-colors duration-200">
    <slot />
    <CookieBanner />
  </body>
</html>
